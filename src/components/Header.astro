---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">경험과 기록</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 1rem;
		background: rgba(252, 252, 252, 0.92);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--line);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.2rem 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	nav a {
		padding: 0.7rem 0.95rem;
		color: rgb(var(--gray-dark));
		border-radius: 999px;
		text-decoration: none;
	}
	nav a.active {
		background: #f2f2f2;
		color: rgb(var(--black));
	}
	nav a:hover {
		background: #f6f6f6;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.8rem 1rem;
		}
		nav {
			width: 100%;
		}
		h2 {
			font-size: 0.9rem;
		}
	}
</style>
