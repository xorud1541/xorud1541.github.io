---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, category, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				display: grid;
				gap: 1.5rem;
			}
			.article-layout {
				display: grid;
				grid-template-columns: 220px minmax(0, 1fr);
				gap: 2rem;
				align-items: start;
			}
			.sidebar {
				position: sticky;
				top: 5.8rem;
			}
			.sidebar-card,
			.article-card {
				border: 1px solid var(--line);
				border-radius: 14px;
				background: #fff;
			}
			.sidebar-card {
				padding: 1rem;
			}
			.meta-label {
				margin: 0 0 0.35rem;
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}
			.meta-block + .meta-block {
				margin-top: 1rem;
				padding-top: 1rem;
				border-top: 1px solid var(--line);
			}
			.meta-value {
				margin: 0;
				color: rgb(var(--gray-dark));
			}
			.hero-image {
				padding: 1rem 1rem 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 10px;
			}
			.prose {
				width: min(100%, 760px);
				max-width: 100%;
				margin: 0 auto;
				padding: 1.8rem 1.2rem 2.4rem;
			}
			.category {
				display: inline-flex;
				align-items: center;
				padding: 0.28rem 0.7rem;
				border-radius: 999px;
				background: #f3f3f3;
				font-size: 0.78rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			h1 {
				margin: 0.9rem 0 0;
				font-size: clamp(2rem, 5vw, 3.4rem);
				line-height: 1.04;
				letter-spacing: -0.04em;
			}
			.description {
				margin: 1rem 0 0;
				color: rgb(var(--gray));
			}
			.date {
				margin-top: 1rem;
				color: rgb(var(--gray));
				font-size: 0.92rem;
			}
			.last-updated-on {
				margin-top: 0.3rem;
				font-style: italic;
			}
			.prose :global(p) {
				margin-bottom: 1.3em;
			}
			.prose :global(h2) {
				margin-top: 2.2rem;
				font-size: 1.7rem;
			}
			.prose :global(h3) {
				margin-top: 1.6rem;
				font-size: 1.3rem;
			}
			@media (max-width: 900px) {
				.article-layout {
					grid-template-columns: 1fr;
				}
				.sidebar {
					position: static;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="article-layout">
				<aside class="sidebar">
					<div class="sidebar-card">
						<div class="meta-block">
							<p class="meta-label">Category</p>
							<p class="meta-value">{category}</p>
						</div>
						<div class="meta-block">
							<p class="meta-label">Published</p>
							<p class="meta-value"><FormattedDate date={pubDate} /></p>
						</div>
						{
							updatedDate && (
								<div class="meta-block">
									<p class="meta-label">Updated</p>
									<p class="meta-value"><FormattedDate date={updatedDate} /></p>
								</div>
							)
						}
					</div>
				</aside>

				<article class="article-card">
					<div class="hero-image">
						{heroImage && <Image width={1200} height={630} src={heroImage} alt="" />}
					</div>
					<div class="prose">
						<div class="category">{category}</div>
						<h1>{title}</h1>
						{description && <p class="description">{description}</p>}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
						<slot />
					</div>
				</article>
			</div>
		</main>
		<Footer />
	</body>
</html>
