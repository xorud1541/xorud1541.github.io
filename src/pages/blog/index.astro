---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const groupedPosts = Object.entries(
	posts.reduce<Record<string, typeof posts>>((groups, post) => {
		const key = post.data.category;
		if (!groups[key]) groups[key] = [];
		groups[key].push(post);
		return groups;
	}, {}),
).sort(([a], [b]) => a.localeCompare(b, 'ko'));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<div class="category-summary">
				{
					groupedPosts.map(([category, categoryPosts]) => (
						<span class="summary-chip">{category} {categoryPosts.length}</span>
					))
				}
			</div>
			{
				groupedPosts.map(([category, categoryPosts]) => (
					<section class="category-section">
						<div class="category-heading">
							<h2>{category}</h2>
							<span>{categoryPosts.length} posts</span>
						</div>
						<ul>
							{
								categoryPosts.map((post) => (
									<li>
										<a href={`/blog/${post.id}/`}>
											<div class="post-header">
												<div class="post-meta">
													<span class="category-badge">{post.data.category}</span>
													<span class="title">{post.data.title}</span>
												</div>
												<span class="date"><FormattedDate date={post.data.pubDate} /></span>
											</div>
											{post.data.description && (
												<p class="description">{post.data.description}</p>
											)}
										</a>
									</li>
								))
							}
						</ul>
					</section>
				))
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 1.5em;
		margin-bottom: 0.75em;
	}
	h2 {
		margin: 0;
		font-size: 1.1em;
	}
	.category-summary {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}
	.summary-chip,
	.category-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		font-size: 0.8rem;
		font-weight: 600;
	}
	.category-section {
		margin-bottom: 2rem;
	}
	.category-heading {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.75rem;
		color: rgb(var(--gray-dark));
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	ul li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	ul li a {
		display: block;
		padding: 1em 0;
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}
	ul li a:hover .title {
		color: rgb(var(--black));
	}
	.post-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
	}
	.title {
		font-weight: 600;
		font-size: 1.1em;
	}
	.date {
		color: rgb(var(--gray));
		font-size: 0.85em;
		white-space: nowrap;
		margin-left: 1em;
	}
	.description {
		margin: 0.5em 0 0 0;
		color: rgb(var(--gray));
		font-size: 0.9em;
		line-height: 1.5;
	}
	@media (max-width: 720px) {
		.category-heading,
		.post-header {
			flex-direction: column;
			gap: 0.25em;
			align-items: flex-start;
		}
		.date {
			margin-left: 0;
		}
	}
</style>
